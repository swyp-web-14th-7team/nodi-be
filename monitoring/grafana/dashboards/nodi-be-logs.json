{
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "에러 수",
      "description": "선택한 시간 범위의 level=error 로그 건수",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "instant",
          "expr": "sum(count_over_time({service=~\"backend_.+\", level=\"error\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "요청 수",
      "description": "pino-http 가 요청마다 남기는 'request completed' 로그 건수",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "instant",
          "expr": "sum(count_over_time({service=~\"backend_.+\"} | json msg=\"msg\" | msg=\"request completed\" [$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "응답시간 p95",
      "description": "느린 요청 감지용. 범위 전체 기준 95 퍼센타일",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "instant",
          "expr": "max(quantile_over_time(0.95, {service=~\"backend_.+\"} | json msg=\"msg\", responseTime=\"responseTime\" | msg=\"request completed\" | unwrap responseTime [$__range]) by (service))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "상태코드별 요청 수",
      "description": "5xx 가 튀는지 보는 용도",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "range",
          "legendFormat": "{{status}}",
          "expr": "sum by (status) (count_over_time({service=~\"backend_.+\"} | json status=\"res.statusCode\" | status != \"\" [$__auto]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 0,
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto"
          },
          "color": { "mode": "palette-classic" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "응답시간 (p50 / p95)",
      "description": "by (service) 가 없으면 로그 한 줄이 각각 별개 시계열이 돼서 분위수가 계산되지 않으니 빼지 말 것",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "range",
          "legendFormat": "p50",
          "expr": "max(quantile_over_time(0.5, {service=~\"backend_.+\"} | json msg=\"msg\", responseTime=\"responseTime\" | msg=\"request completed\" | unwrap responseTime [$__auto]) by (service))"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "range",
          "legendFormat": "p95",
          "expr": "max(quantile_over_time(0.95, {service=~\"backend_.+\"} | json msg=\"msg\", responseTime=\"responseTime\" | msg=\"request completed\" | unwrap responseTime [$__auto]) by (service))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "logs",
      "title": "에러 로그",
      "description": "한 줄 요약만 표시. 줄을 클릭하면 req_id·url·상태코드 등 payload 가 펼쳐짐",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "range",
          "expr": "{service=~\"backend_.+\", level=\"error\"} | json | line_format \"{{if .req_method}}{{.req_method}} {{.req_url}} → {{.res_statusCode}} ({{.responseTime}}ms){{else}}{{.msg}}{{end}}\""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "type": "logs",
      "title": "백엔드 전체 로그",
      "description": "요청 로그는 'GET /url → 200 (12ms)' 로, 그 외 앱 로그는 msg 로 한 줄 표시. 클릭하면 필드별 payload 를 볼 수 있고, 값 옆 돋보기로 그 값만 필터링 가능",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "range",
          "expr": "{service=~\"backend_.+\"} | json | line_format \"{{if .req_method}}{{.req_method}} {{.req_url}} → {{.res_statusCode}} ({{.responseTime}}ms){{else}}{{.msg}}{{end}}\""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nodi-be"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
