generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// -------------- 유저 --------------
model User {
  id              String  @id @default(ulid()) @db.Char(26)
  name            String  @db.VarChar(255) // 실제 본명 (소셜 로그인 시 딸려오는 이름)
  nickname        String  @db.VarChar(255) // 서비스에서 사용할 닉네임
  email           String  @unique @db.VarChar(255) // 소셜 로그인 이메일 (중복 불가) 소프트 딜리트 시 deleted-{id}-{email} 형식으로 변경된다. TODO: 길이 초과되면 어떻할지 정하기! -> 그냥 해시해서 저장하자!
  profileImageUrl String? @map("profile_image_url") @db.VarChar(500)
  role            Int     @default(0) @db.TinyInt // 0: 일반 유저, 1: ADMIN

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3) // 소프트 딜리드 시점 (유저 정보는 일정기간 보관한다.)

  auths            UserAuth[]
  refreshTokens    RefreshToken[]
  profileCards     UserProfileCard[]
  collections      UserCollection[]
  collectionGroups CollectionGroup[]

  @@map("users")
}

model UserAuth {
  id         Int    @id @default(autoincrement()) @db.UnsignedInt
  provider   String @db.VarChar(20) // google, ...
  providerId String @map("provider_id") @db.VarChar(255)

  userId String @map("user_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@unique([userId, provider])
  @@unique([provider, providerId])
  @@map("user_auths")
}

model RefreshToken {
  id       Int    @id @default(autoincrement()) @db.UnsignedInt
  deviceId String @map("device_id") @db.Char(36)
  token    String @db.Char(64) // refreshToken 의 sha256 해시값

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  revokedAt DateTime? @map("revoked_at") @db.DateTime(3)

  userId String @map("user_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deviceId, token])
  @@unique([userId, deviceId])
  @@map("refresh_tokens")
}

// -------------- 직업 종류 --------------
model JobType {
  id            Int               @id @default(autoincrement()) @db.UnsignedInt
  name          String            @unique @db.VarChar(100) // 이 값은 수정할 수 없음. 다른게 필요하다면 새로 생성할 것.
  personalities Personality[]
  profileCards  UserProfileCard[]

  @@map("job_types")
}

// -------------- 유저 프로필 카드 --------------
model UserProfileCard {
  id              String  @id @default(ulid()) @db.Char(26)
  nickname        String  @db.VarChar(255) // 프로필 카드 닉네임, 기본값은 user.name
  cardImageUrl    String? @map("card_image_url") @db.VarChar(500) // 프로필 카드 배경 이미지 url
  profileImageUrl String? @map("profile_image_url") @db.VarChar(500) // 프로필 이미지 url
  description     String  @default("") @db.VarChar(2000)

  userId String @map("user_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean? @map("is_default")

  // 카드가 속한 직군 (필수)
  jobTypeId Int     @map("job_type_id") @db.UnsignedInt
  jobType   JobType @relation(fields: [jobTypeId], references: [id], onDelete: Restrict)

  // 카드당 개성 하나만 선택
  personalityId Int?         @map("personality_id") @db.UnsignedInt
  personality   Personality? @relation(fields: [personalityId], references: [id], onDelete: Restrict)

  // 카드당 현 소속 상태 하나만 선택
  affiliationStatusId Int?               @map("affiliation_status_id") @db.UnsignedInt
  affiliationStatus   AffiliationStatus? @relation(fields: [affiliationStatusId], references: [id], onDelete: Restrict)

  // 카드당 목적 하나만 선택 (팀 빌딩/친목/커피챗 등)
  purposeId Int?     @map("purpose_id") @db.UnsignedInt
  purpose   Purpose? @relation(fields: [purposeId], references: [id], onDelete: Restrict)

  // 현 소속 (자유 입력, 100자 이내)
  affiliation String? @db.VarChar(255)

  profileCardSkills    ProfileCardSkill[]
  profileCardInterests ProfileCardInterest[]
  userCollections      UserCollection[]
  profileCardLinks     ProfileCardLink[]

  @@unique([userId, isDefault])
  @@map("user_profile_cards")
}

// -------------- 관심사 --------------
model Interest {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100)

  profileCardInterests ProfileCardInterest[]

  @@map("interests")
}

model ProfileCardInterest {
  profileCardId String          @map("profile_card_id") @db.Char(26)
  profileCard   UserProfileCard @relation(fields: [profileCardId], references: [id], onDelete: Cascade)

  interestId Int      @map("interest_id") @db.UnsignedInt
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Restrict)

  @@id([profileCardId, interestId])
  @@map("profile_card_interests")
}

// -------------- 유저 스킬 --------------
model SkillCategory {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100) // language, framwork, design tools ...

  skills Skill[]

  @@map("skill_categories")
}

model Skill {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100)

  categoryId Int           @map("category_id") @db.UnsignedInt
  category   SkillCategory @relation(fields: [categoryId], references: [id])

  profileCardSkills ProfileCardSkill[]

  @@map("skills")
}

model ProfileCardSkill {
  profileCardId String          @map("profile_card_id") @db.Char(26)
  profileCard   UserProfileCard @relation(fields: [profileCardId], references: [id], onDelete: Cascade)

  skillId Int   @map("skill_id") @db.UnsignedInt
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([profileCardId, skillId])
  @@map("profile_card_skills")
}

// -------------- 개성 --------------
model Personality {
  id          Int    @id @default(autoincrement()) @db.UnsignedInt
  name        String @unique @db.VarChar(100)
  description String @db.VarChar(2000)

  jobTypeId Int?     @map("job_type_id") @db.UnsignedInt // 관련 직군, null: 공통
  jobType   JobType? @relation(fields: [jobTypeId], references: [id], onDelete: Restrict)

  imageUrl String? @map("image_url") @db.VarChar(500)

  profileCards UserProfileCard[]

  @@map("personalities")
}

// 현 소속 상태 선택지 (재직중/구직중/재학중 등). 카드당 하나 선택
model AffiliationStatus {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100)

  profileCards UserProfileCard[]

  @@map("affiliation_statuses")
}

// 프로필 카드 목적 선택지 (팀 빌딩/친목/커피챗 등). 카드당 하나 선택
model Purpose {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100)

  profileCards UserProfileCard[]

  @@map("purposes")
}

// 프로필 카드 링크
model ProfileCardLink {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  profileCardId String          @map("profile_card_id") @db.Char(26)
  profileCard   UserProfileCard @relation(fields: [profileCardId], references: [id], onDelete: Cascade)

  // 0: EMAIL, 1: INSTAGRAM, 2: GITHUB, 3: LINKEDIN, 4: BEHANCE, 5: NOTION, 6: WEBSITE
  type  Int    @db.TinyInt
  value String @db.VarChar(500) // 링크(URL) 또는 이메일 값

  @@map("profile_card_links")
}

// -------------- 스크랩 --------------
model CollectionGroup {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @db.VarChar(100)

  userId          String           @map("user_id") @db.Char(26)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userCollections UserCollection[]

  @@unique([userId, name])
  @@map("collection_groups")
}

model UserCollection {
  id     Int    @id @default(autoincrement()) @db.UnsignedInt
  userId String @map("user_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  groupId Int?             @map("group_id") @db.UnsignedInt
  group   CollectionGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  cardId String?          @map("card_id") @db.Char(26)
  card   UserProfileCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@unique([userId, groupId, cardId])
  @@map("user_collections")
}
