generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// -------------- 유저 --------------
model User {
  id       String @id @default(ulid()) @db.Char(26)
  name     String @db.VarChar(255) // 실제 본명 (소셜 로그인 시 딸려오는 이름)
  nickname String @db.VarChar(255) // 서비스에서 사용할 닉네임
  email    String @unique @db.VarChar(255) // 소셜 로그인 이메일 (중복 불가) 소프트 딜리트 시 deleted-{id}-{email} 형식으로 변경된다. TODO: 길이 초과되면 어떻할지 정하기!
  role     Int    @default(0) @db.TinyInt // 0: 일반 유저, 1: ADMIN

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3) // 소프트 딜리드 시점 (유저 정보는 일정기간 보관한다.)

  auths         UserAuth[]
  refreshTokens RefreshToken[]
  jobDetails    JobDetail[]

  @@map("users")
}

model UserAuth {
  id         Int    @id @default(autoincrement()) @db.UnsignedInt
  provider   String @db.VarChar(20) // google, ...
  providerId String @map("provider_id") @db.VarChar(255)

  userId String @map("user_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@unique([userId, provider])
  @@unique([provider, providerId])
  @@map("user_auths")
}

model RefreshToken {
  id       Int    @id @default(autoincrement()) @db.UnsignedInt
  deviceId String @map("device_id") @db.Char(36)
  token    String @db.Char(64) // refreshToken 의 sha256 해시값

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  revokedAt DateTime? @map("revoked_at") @db.DateTime(3)

  userId String @map("user_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deviceId, token])
  @@unique([userId, deviceId])
  @@map("refresh_tokens")
}

// -------------- 직군 (기본 프로필 카드 정보) --------------
model JobDetail {
  id       Int    @id @default(autoincrement()) @db.UnsignedInt
  nickname String @db.VarChar(255) // 프로필 카드 닉네임, 기본값은 user.name

  userId String @map("user_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  isActive  Boolean  @default(true) @map("is_active")

  templateId Int?                 @map("template_id") @db.UnsignedInt
  template   ProfileCardTemplate? @relation(fields: [templateId], references: [id], onDelete: Restrict)

  userSkills     JobSkill[]
  userInterests  JobInterest[]
  jobDetailItems JobDetailItem[]

  @@map("job_details")
}

// -------------- 관심사 --------------
model Interest {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100)

  userInterests JobInterest[]

  @@map("interests")
}

model JobInterest {
  jobDetailId Int       @map("job_detail_id") @db.UnsignedInt
  jobDetail   JobDetail @relation(fields: [jobDetailId], references: [id], onDelete: Cascade)

  interestId Int      @map("interest_id") @db.UnsignedInt
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Restrict)

  @@id([jobDetailId, interestId])
  @@map("user_interests")
}

// -------------- 유저 스킬 --------------
model SkillCategory {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100) // language, framwork, design tools ...

  skills Skill[]

  @@map("skill_categories")
}

model Skill {
  id   Int    @id @default(autoincrement()) @db.UnsignedInt
  name String @unique @db.VarChar(100)

  categoryId Int           @map("category_id") @db.UnsignedInt
  category   SkillCategory @relation(fields: [categoryId], references: [id])

  jobSkills JobSkill[]

  @@map("skills")
}

model JobSkill {
  jobDetailId Int       @map("job_detail_id") @db.UnsignedInt
  jobDetail   JobDetail @relation(fields: [jobDetailId], references: [id], onDelete: Cascade)

  skillId Int   @map("skill_id") @db.UnsignedInt
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([jobDetailId, skillId])
  @@map("user_skills")
}

// 상세 탬플릿
// 템플릿은 jobDetail 테이블에 JSON 형식으로 저장할 예정 -> jobDetailItem 에 저장
model ProfileCardTemplate {
  id      Int    @id @default(autoincrement()) @db.UnsignedInt
  name    String @db.VarChar(255) // 직군명이 될 것! (백엔드 개발자 .. )
  version Int    @default(1) // 직군별 버전 탬플릿은 수정이 불가능함 (유저가 이미 사용중인경우) 이 경우에는 새 버전을 만드는 것으로 해결함

  profileCardTemplateItems ProfileCardTemplateItemType[]
  jobDetails               JobDetail[]

  @@unique([name, version])
  @@map("profile_card_templates")
}

model ProfileCardTemplateItemType {
  id          Int    @id @default(autoincrement()) @db.UnsignedInt
  label       String @db.VarChar(255) // 항목 이름
  description String @db.VarChar(2000) // 항목 설명
  type        Int    @db.TinyInt // 항목 타입 (0: SHORT_TEXT, 1: LONG_TEXT, 2: LINK, 3: NUMBER)

  templateId     Int                 @db.UnsignedInt
  template       ProfileCardTemplate @relation(fields: [templateId], references: [id])
  jobDetailItems JobDetailItem[]

  @@map("profile_card_template_item_types")
}

model JobDetailItem {
  id    Int  @id @default(autoincrement()) @db.UnsignedInt
  value Json // 각 타입에 맞는 값

  jobDetailId Int       @map("job_detail_id") @db.UnsignedInt
  jobDetail   JobDetail @relation(fields: [jobDetailId], references: [id])

  itemTypeId Int                         @map("item_type_id") @db.UnsignedInt
  itemType   ProfileCardTemplateItemType @relation(fields: [itemTypeId], references: [id])

  @@unique([jobDetailId, itemTypeId])
  @@map("job_detail_items")
}
