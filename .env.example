# dev | prod
NODE_ENV=dev

# DB config
DATABASE_URL="mysql://root:1234@localhost:3306/testDB"
# db ca 인증서 위치 (optional)
DB_SSL_CA_PATH=certs/ca.pem

ADMIN_EMAIL=admin@sample.com

# google cloud config
GOOGLE_CLIENT_ID=sersdf.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=DFSOEN...
# redirect_uri = 요청 origin + 이 경로 (구글 콘솔 승인 리디렉션 URI 에 등록 필요)
GOOGLE_REDIRECT_PATH=/oauth-test.html

# naver developers config
NAVER_CLIENT_ID=naverClientId
NAVER_CLIENT_SECRET=naverClientSecret
# redirect_uri = 요청 origin + 이 경로 (네이버 개발자센터 Callback URL 에 등록 필요)
NAVER_REDIRECT_PATH=/oauth-test.html

# kakao developers config
KAKAO_CLIENT_ID=kakaoRestApiKey
# client_secret 은 카카오 콘솔에서 활성화한 경우에만 필요 (선택)
KAKAO_CLIENT_SECRET=
# redirect_uri = 요청 origin + 이 경로 (카카오 개발자 Redirect URI 에 등록 필요)
KAKAO_REDIRECT_PATH=/oauth-test.html

# redis config
REDIS_HOST=localhost
REDIS_PORT=6379
# optional
REDIS_USERNAME=
REDIS_PASSWORD=

# aws config
AWS_ACCESS_KEY_ID=ASDAF...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=aws-region
AWS_BUCKET_NAME=bucket
AWS_CLOUDFRONT_DOMAIN=dsfdsf.cloudfront.net

# jwt secrets
JWT_SECRET=secretKey
JWT_REFRESH_SECRET=secretRefreshKey

# grafana admin 비밀번호 (id 는 admin)
# 로컬 개발(.env)에는 필요 없고, 배포용 .env.deploy 에만 있으면 됨.
# docker-compose.yml 의 grafana 서비스가 .env.deploy 에서 읽는다.
# 비워두면 Grafana 가 에러 없이 admin/admin 으로 뜨고, 3000 포트가 공개돼 있어
# 사실상 로그 전체가 무방비가 됨. 반드시 임의의 긴 값으로 채울 것.
#   openssl rand -base64 24
GF_SECURITY_ADMIN_PASSWORD=
